ENVIRONMENT=dev
LOG_LEVEL=INFO

# Inbound API auth (portal JWT validation).
# Leave blank in dev to bypass auth entirely.
ENTRA_APP_CLIENT_ID=
ENTRA_APP_TENANT_ID=common
ENTRA_API_AUDIENCE=

# Outbound Graph auth.
GRAPH_AUTH_MODE=secret
GRAPH_CLIENT_SECRET=
GRAPH_MANAGED_IDENTITY_CLIENT_ID=

# Storage.
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./evidence_store

# CORS (JSON array).
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
