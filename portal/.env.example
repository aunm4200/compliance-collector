# ── Runtime env vars (set on the server / Container App — no rebuild needed) ──
#
# These are read by /api/config at request time, so you can change them in
# Azure Container Apps environment variables without rebuilding the image.

ENTRA_CLIENT_ID=                                           # App registration client ID
ENTRA_AUTHORITY=https://login.microsoftonline.com/common   # Use /common for multi-tenant
ENTRA_REDIRECT_URI=https://<your-portal-hostname>/auth/callback
ENTRA_API_SCOPE=api://<client-id>/access_as_user

# Backend URL — read server-side by the Next.js proxy route at runtime
BACKEND_URL=http://localhost:8080

# Dev bypass: skips MSAL entirely (backend must also have ENTRA_APP_CLIENT_ID unset + ENVIRONMENT=dev)
# Set to "true" only for local development. This IS baked in at build time.
DEV_BYPASS_AUTH=false

# ── Local development only (.env.local) ──────────────────────────────────────
# For local dev with real auth, copy the block above into .env.local and fill in values.
# For local dev without auth (bypass mode), set DEV_BYPASS_AUTH=true and leave Entra vars empty.
