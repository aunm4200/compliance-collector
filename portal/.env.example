# Entra app registration (same multi-tenant app the backend validates against)
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_AUTHORITY=https://login.microsoftonline.com/common
NEXT_PUBLIC_ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_ENTRA_API_SCOPE=api://CHANGE_ME/access_as_user

# Backend URL (used by the Next.js server-side rewrite)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Dev bypass: when true, portal skips MSAL and calls the backend in dev mode
NEXT_PUBLIC_DEV_BYPASS_AUTH=true
